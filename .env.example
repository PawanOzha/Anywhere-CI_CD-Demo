# --- Railway Production Signaling Server ---
# ANYWHERE_SIGNALING_WSS=wss://bug-free-robot-production.up.railway.app
# ANYWHERE_SIGNALING_HTTP=https://bug-free-robot-production.up.railway.app
ANYWHERE_SIGNALING_WSS=wss://10.80.80.242:8085
WS_CONNECT_TOKEN=change_me_ws_connect_token

# --- Local dev fallback (signaling-server: npm run dev, default PORT 8085) ---
# Uncomment to use local signaling server instead:
# ANYWHERE_SIGNALING_WSS=ws://localhost:8085

# Optional: HTTP base for call-event REST API when it differs from the WSS host
# (defaults to same host as ANYWHERE_SIGNALING_WSS: wss:// → https://, ws:// → http://)
# ANYWHERE_SIGNALING_HTTP=https://your-host.example
PORT=8085
INGEST_TOKEN_SECRET=some_long_random_value
INGEST_TOKEN_TTL_MS=900000
ENFORCE_TLS=false

# --- Packaged build: OTA vs local installer ---
# Default `npm run build` embeds ANYWHERE_UPDATE_BASE_URL from `.env.r2` (R2) when set, and enables auto-update.
# For a local Windows installer with NO auto-update (no R2/GitHub feed checks):
#   npm run build:local
# Equivalent: ANYWHERE_NO_OTA=1 npm run build
# ANYWHERE_UPDATE_BASE_URL=https://your-r2-or-cdn/client-folder